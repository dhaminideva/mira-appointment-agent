# ── Observe Insurance ARIA — .env ────────────────────────────────────────────

# ── LLM — OpenRouter (free, no permissions issues) ────────────────────────────
LLM_PROVIDER=openrouter
GROQ_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://openrouter.ai/api/v1

# ── STT — Deepgram ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── TTS — ElevenLabs ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Telephony — Twilio (real phone number, free trial) ───────────────────────
# Sign up at twilio.com — free trial gives $15.50 credit, no card needed
# Console → Account Info → Account SID and Auth Token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Console → Phone Numbers → Manage → Active Numbers → your number
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Port the Flask voice server runs on
PORT=5050

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── n8n webhooks (fill after ngrok is running) ────────────────────────────────
# IMPORTANT: ngrok must tunnel port 5678 for n8n AND port 5050 for voice server
# Use two separate ngrok tunnels OR one ngrok config file (see README)
N8N_WEBHOOK_BASE_URL=https://cade-inbred-riva.ngrok-free.dev/webhook
